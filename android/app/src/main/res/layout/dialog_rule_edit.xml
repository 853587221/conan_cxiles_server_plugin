<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="规则名称"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edit_rule_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_edittext"
            android:hint="输入规则名称（可选）"
            android:inputType="text"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="触发条件（点击添加）"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <GridLayout
            android:id="@+id/grid_conditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="3"
            android:rowCount="4"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <Button
                android:id="@+id/btn_condition_keyword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="🔤 关键词"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent" />

            <Button
                android:id="@+id/btn_condition_amount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="💰 *金额*"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent_dark" />

            <Button
                android:id="@+id/btn_condition_tag"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="🏷️ *标签*"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent_dark" />

            <Button
                android:id="@+id/btn_condition_level"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="📊 等级"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent" />

            <Button
                android:id="@+id/btn_condition_playtime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="⏱️ 在线时间"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent" />

            <Button
                android:id="@+id/btn_condition_new_player"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="🧒 新玩家"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent" />

            <Button
                android:id="@+id/btn_condition_server_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="📅 *时间*"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent_dark" />

            <Button
                android:id="@+id/btn_condition_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="🎒 *背包*"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent_dark" />

            <Button
                android:id="@+id/btn_condition_vip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="2dp"
                android:text="👑 *会员*"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minHeight="48dp"
                android:gravity="center"
                android:backgroundTint="@color/accent_dark" />

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="已添加的条件："
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/container_added_conditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="8dp"
            android:minHeight="60dp">

            <TextView
                android:id="@+id/text_no_conditions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="暂无添加的条件"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:padding="16dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="执行类型"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinner_execute_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_edittext"
            android:padding="12dp" />

        <LinearLayout
            android:id="@+id/container_single_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择命令"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_select_command"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="点击选择命令"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:gravity="start|center_vertical"
                android:padding="12dp"
                android:backgroundTint="@color/primary" />

            <TextView
                android:id="@+id/text_selected_command"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_category_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择命令分类"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="金额操作"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinner_amount_operation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext"
                android:padding="12dp" />

            <EditText
                android:id="@+id/edit_amount_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="金额"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="设置权限标签"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edit_set_tag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_edittext"
            android:hint="输入要设置的权限标签值（可选）"
            android:inputType="text"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="私发通知消息（条件未通过时）"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_fail_notification"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext"
                android:gravity="top|start"
                android:hint="条件未通过时发送给玩家的通知消息（可选）"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:minLines="2"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_insert_fail_variable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="📌 变量"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:minWidth="60dp"
                android:backgroundTint="@color/info" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_fail_variables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="8dp"
            android:visibility="gone"
            android:maxHeight="200dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="可用的变量，点击自动插入："
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="vertical">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <Button
                        android:id="@+id/btn_var_fail_char_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@角色名"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/error" />

                    <Button
                        android:id="@+id/btn_var_fail_clan_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@部落名"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/warning" />

                    <Button
                        android:id="@+id/btn_var_fail_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@金额"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/success" />

                    <Button
                        android:id="@+id/btn_var_fail_level"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@等级"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/info" />

                    <Button
                        android:id="@+id/btn_var_fail_playtime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@在线时间"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/warning" />

                    <Button
                        android:id="@+id/btn_var_fail_tag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@权限标签"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/accent" />

                    <Button
                        android:id="@+id/btn_var_fail_respawn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@复活点"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/pink" />

                    <Button
                        android:id="@+id/btn_var_fail_vip_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@会员时间"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/accent_dark" />

                </GridLayout>

            </ScrollView>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="私发通知消息（条件通过后）"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_notification"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext"
                android:gravity="top|start"
                android:hint="条件通过后发送给玩家的通知消息（可选）"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:minLines="2"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_insert_variable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="📌 变量"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:minWidth="60dp"
                android:backgroundTint="@color/info" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_variables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="8dp"
            android:visibility="gone"
            android:maxHeight="200dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="可用的变量，点击自动插入："
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="vertical">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <Button
                        android:id="@+id/btn_var_char_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@角色名"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/error" />

                    <Button
                        android:id="@+id/btn_var_clan_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@部落名"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/warning" />

                    <Button
                        android:id="@+id/btn_var_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@金额"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/success" />

                    <Button
                        android:id="@+id/btn_var_level"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@等级"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/info" />

                    <Button
                        android:id="@+id/btn_var_playtime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@在线时间"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/warning" />

                    <Button
                        android:id="@+id/btn_var_tag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@权限标签"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/accent" />

                    <Button
                        android:id="@+id/btn_var_respawn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@复活点"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/pink" />

                    <Button
                        android:id="@+id/btn_var_vip_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="2dp"
                        android:text="@会员时间"
                        android:textAllCaps="false"
                        android:textSize="10sp"
                        android:minHeight="36dp"
                        android:backgroundTint="@color/accent_dark" />

                </GridLayout>

            </ScrollView>

        </LinearLayout>

        <Button
            android:id="@+id/btn_save_rule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="💾 保存自动触发规则"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="@color/success" />

    </LinearLayout>

</ScrollView>
