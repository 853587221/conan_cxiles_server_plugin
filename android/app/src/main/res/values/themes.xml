<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RconClient" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_light</item>
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="CardStyle">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="ButtonPrimary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="ButtonSuccess" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_success</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonDanger" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="EditTextStyle">
        <item name="android:background">@drawable/bg_edittext</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="TitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="ConsoleText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/console_text</item>
    </style>

    <style name="InfoRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="InfoLabel">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="InfoValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="InfoValueGreen" parent="InfoValue">
        <item name="android:textColor">@color/success</item>
    </style>

    <style name="InfoValueRed" parent="InfoValue">
        <item name="android:textColor">@color/error</item>
    </style>

    <style name="InfoValueOrange" parent="InfoValue">
        <item name="android:textColor">@color/warning</item>
    </style>

    <style name="InfoValueBlue" parent="InfoValue">
        <item name="android:textColor">@color/info</item>
    </style>

    <style name="InfoValuePink" parent="InfoValue">
        <item name="android:textColor">@color/pink</item>
    </style>

    <style name="StatRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="StatLabel">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="StatValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="StatValueRed" parent="StatValue">
        <item name="android:textColor">@color/error</item>
    </style>

    <style name="StatValueGreen" parent="StatValue">
        <item name="android:textColor">@color/success</item>
    </style>

    <style name="StatValueBlue" parent="StatValue">
        <item name="android:textColor">@color/info</item>
    </style>

    <style name="StatValuePurple" parent="StatValue">
        <item name="android:textColor">@color/purple</item>
    </style>

    <style name="StatValueOrange" parent="StatValue">
        <item name="android:textColor">@color/warning</item>
    </style>

    <style name="StatValueCyan" parent="StatValue">
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="StatEditBtn">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:text">修改</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="StatEditBtnRed" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/error_transparent</item>
        <item name="android:textColor">@color/error</item>
    </style>

    <style name="StatEditBtnGreen" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/success_transparent</item>
        <item name="android:textColor">@color/success</item>
    </style>

    <style name="StatEditBtnBlue" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/info_transparent</item>
        <item name="android:textColor">@color/info</item>
    </style>

    <style name="StatEditBtnPurple" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/purple_transparent</item>
        <item name="android:textColor">@color/purple</item>
    </style>

    <style name="StatEditBtnOrange" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/warning_transparent</item>
        <item name="android:textColor">@color/warning</item>
    </style>

    <style name="StatEditBtnCyan" parent="StatEditBtn">
        <item name="android:backgroundTint">@color/accent_transparent</item>
        <item name="android:textColor">@color/accent</item>
    </style>
</resources>
